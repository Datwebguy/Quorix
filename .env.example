# Copy to .env and fill in real values. Never commit .env.

# X Layer RPC
X_LAYER_RPC_URL=https://rpc.xlayer.tech

# Reference / hackathon on-chain contracts (X Layer mainnet)
ESCROW_CONTRACT_ADDRESS=0x599e23D6073426eBe357d03056258eEAa217e01D
RATING_CONTRACT_ADDRESS=0x85Be67F1A3c1f470A6c94b3C77fD326d3c0f1188
USDC_TOKEN_ADDRESS=0x74b7F16337b8972027F6196A17a631aC6dE26d22

# QuorixASP broker identity (OKX.AI agent registry)
AGENT_ID=your_agent_id_here

# Isolated OKX CLI session hash (16-char hex from operator email login)
# Derives ONCHAINOS_HOME = %TEMP%/okx-cli-sessions/<hash>
ONCHAINOS_CLI_SESSION=your_session_hash_here

# Operator email — used only by local dev helper scripts (asp-login-*, etc.)
OKX_OPERATOR_EMAIL=your_email@example.com

# Optional: path to agent avatar PNG for asp-register-precheck.js
OKX_AGENT_AVATAR_PATH=

# Marketplace discovery
MARKETPLACE_LOOKBACK_BLOCKS=1800

# Public HTTPS URL for A2MCP / ASP service registration (Cloudflare tunnel, etc.)
PUBLIC_BASE_URL=https://your-public-url.example.com

# Admin panel password (required — server refuses to start without it)
ADMIN_PASSWORD=changeme

# Server
PORT=3001
POLL_INTERVAL_MS=120000
MAX_POLL_ATTEMPTS=20

# Broker SLA (optional overrides)
BROKER_FEE_BPS=100
MIN_REPUTATION_SCORE=3.0
MAX_DISPUTE_RATE=0.20
A2MCP_CALL_PRICE_OKB=0.005

# Registered A2A service fee displayed in the UI (match your OKX.AI listing)
A2A_SERVICE_FEE_USDT=0.5